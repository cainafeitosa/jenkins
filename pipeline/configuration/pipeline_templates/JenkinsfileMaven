#!/usr/bin/env groovy

podTemplate(cloud: "kubernetes", inheritFrom: "maven-jdk-8") {
  node(POD_LABEL) {
    stage("Checkout SCM") {
      checkout_scm()
    }

    stage("Maven: Compile") {
      container("maven") {
        mvn("clean", "compile")
      }
    }

    stage("Maven: Unit Test") {
      when(! pipelineConfig?.workflow?.skip_unit_test) {
        container("maven") {
          mvn("test")
        }
      }
    }

    stage("Maven: Install") {
      container("maven") {
        mvn("-DskipTests", "install")
      }
    }

    // stage("Docker: Build Image") {
    //   docker.build()
    // }

    // stage("Docker: Build Push") {
    //   docker.push()
    // }
  }
}