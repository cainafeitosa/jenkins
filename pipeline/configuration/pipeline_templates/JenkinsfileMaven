#!/usr/bin/env groovy

podTemplate(cloud: "kubernetes", inheritFrom: "maven-jdk-8") {
  node(POD_LABEL) {
    stage("Checkout SCM") {
      checkout_scm()
    }

    stage("Maven: Compile") {
      container("maven") {
        mvn("clean", "compile")
      }
    }

    stage("Maven: Test") {
      when(! pipelineConfig?.workflow?.skip_unit_test) {
        container("maven") {
          mvn("test")
        }
      }
    }

    stage("Maven: Install") {
      container("maven") {
        mvn("-DskipTests", "install")
      }
    }

    stage("Docker: Build") {
      container("docker") {
        builtImage = build_container_image()
        println builtImage.getClass()
      }
    }

    // stage("Docker: Push") {
    //   container("docker") {
    //     push_container_image(builtImage)
    //   }
    // }
  }
}